generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("USER") // USER | ADMIN
  orders    Order[]
  createdAt DateTime @default(now())
}

model Book {
  id          String      @id @default(cuid())
  title       String      // English / transliterated title
  titleBn     String      @default("") // Bangla title
  author      String
  publisher   String      @default("") // e.g. Lecture, Panjeree, Royal
  description String
  price       Float
  // Academic classification (National University)
  program     String      @default("Honours") // Honours | Degree | Masters
  year        String      @default("") // 1st Year ... 4th Year | Preliminary | Final
  category    String      // Subject / Department, e.g. Accounting, Bangla
  bookType    String      @default("Textbook") // Textbook | Guide | Suggestion | Notes
  coverImage  String
  stock       Int         @default(0)
  rating      Float       @default(0)
  featured    Boolean     @default(false)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
}

model Order {
  id          String      @id @default(cuid())
  user        User        @relation(fields: [userId], references: [id])
  userId      String
  items       OrderItem[]
  total       Float
  status      String      @default("PENDING") // PENDING | PAID | SHIPPED | DELIVERED | CANCELLED
  // Shipping
  fullName    String
  phone       String
  address     String
  city        String
  // Payment
  paymentMethod String    @default("MOCK")
  paymentRef    String?
  createdAt   DateTime    @default(now())
}

model OrderItem {
  id       String @id @default(cuid())
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId  String
  book     Book   @relation(fields: [bookId], references: [id])
  bookId   String
  title    String
  price    Float
  quantity Int
}
